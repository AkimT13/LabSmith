# Docker Compose defaults for local deployment smoke tests.
# Copy to .env at the repo root before running docker compose if you need real
# Clerk/OpenAI credentials or non-default ports.

POSTGRES_DB=labsmith
POSTGRES_USER=labsmith
POSTGRES_PASSWORD=labsmith
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Frontend build/runtime config
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Backend Clerk config
LABSMITH_CLERK_SECRET_KEY=sk_test_...
LABSMITH_CLERK_PUBLISHABLE_KEY=pk_test_...
LABSMITH_CLERK_WEBHOOK_SECRET=whsec_...
LABSMITH_CLERK_JWKS_URL=

# Optional M7 OpenAI config
LABSMITH_CHAT_LLM_PROVIDER=mock
LABSMITH_SPEC_EXTRACTOR=rule_based
LABSMITH_OPENAI_API_KEY=
LABSMITH_OPENAI_CHAT_MODEL=gpt-4o-mini
LABSMITH_OPENAI_EXTRACTION_MODEL=gpt-4o-mini

# M8 chat hardening
LABSMITH_CHAT_RATE_LIMIT_REQUESTS=30
LABSMITH_CHAT_RATE_LIMIT_WINDOW_SECONDS=60
LABSMITH_SSE_KEEPALIVE_INTERVAL_SECONDS=15
