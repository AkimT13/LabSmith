{
  "name": "labsmith",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "setup": "pip install -e '.[dev]' && npm install && npm run backend:migrate",
    "backend:install": "pip install -e '.[dev]'",
    "backend:dev": "python3 -m uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port 8000",
    "backend:dev:reload": "python3 -m uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port 8000 --reload",
    "backend:test": "python3 -m pytest backend/tests",
    "backend:migrate": "cd backend && python3 -m alembic upgrade head",
    "backend:migration:create": "cd backend && python3 -m alembic revision --autogenerate -m",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:lint": "npm --prefix frontend run lint"
  }
}
