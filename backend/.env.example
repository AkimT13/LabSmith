# Database
LABSMITH_DATABASE_URL=postgresql+asyncpg://labsmith:labsmith@localhost:5432/labsmith

# Clerk
LABSMITH_CLERK_SECRET_KEY=sk_test_...
LABSMITH_CLERK_PUBLISHABLE_KEY=pk_test_...
LABSMITH_CLERK_WEBHOOK_SECRET=whsec_...

# App
LABSMITH_DEBUG=false

# Chat / M3 — when true the chat endpoint uses scripted text/pacing instead of
# a real LLM. CAD generation still runs through the real CadQuery pipeline.
LABSMITH_CHAT_MOCK=true

# Storage / M4 — only "local" is supported today.
LABSMITH_STORAGE_BACKEND=local
LABSMITH_STORAGE_DIR=./backend/storage

# LLM / M7 — Smart parsing & iterative refinement.
# - chat_llm_provider controls who writes the assistant's reply text.
#   "mock" (default) emits a canned response with no network calls.
#   "openai" streams via the OpenAI Chat Completions API.
# - spec_extractor controls who turns the user prompt into a PartRequest.
#   "rule_based" (default) uses the regex parser.
#   "openai" uses an OpenAI structured-output call that also reads the
#   session's current_spec + recent message history (enables iterative
#   refinement like "make the wells deeper"). Falls back to rule_based
#   on any failure, so a misconfigured key never crashes a chat turn.
# Both default to the safe local option so the backend works without a key.
LABSMITH_CHAT_LLM_PROVIDER=mock
LABSMITH_SPEC_EXTRACTOR=rule_based

# Required when CHAT_LLM_PROVIDER=openai or SPEC_EXTRACTOR=openai.
LABSMITH_OPENAI_API_KEY=
LABSMITH_OPENAI_CHAT_MODEL=gpt-4o-mini
LABSMITH_OPENAI_EXTRACTION_MODEL=gpt-4o-mini
