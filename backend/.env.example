# Database
LABSMITH_DATABASE_URL=postgresql+asyncpg://labsmith:labsmith@localhost:5432/labsmith

# Clerk
LABSMITH_CLERK_SECRET_KEY=sk_test_...
LABSMITH_CLERK_PUBLISHABLE_KEY=pk_test_...
LABSMITH_CLERK_WEBHOOK_SECRET=whsec_...
LABSMITH_CLERK_JWKS_URL=https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json

# App
LABSMITH_DEBUG=false

# Chat / M3
# When true (default), the chat endpoint uses the mock LLM and skips real CAD
# generation. Tests rely on this being true.
LABSMITH_CHAT_MOCK=true

# LLM provider for assistant text streaming. "mock" needs no setup; "openai"
# requires LABSMITH_OPENAI_API_KEY. Default is "mock" so accidentally hitting
# /chat without an API key never costs money.
LABSMITH_CHAT_LLM_PROVIDER=mock

# Only needed when CHAT_LLM_PROVIDER=openai. Install the openai extra:
#   pip install -e '.[llm]'
LABSMITH_OPENAI_API_KEY=
LABSMITH_OPENAI_MODEL=gpt-4o-mini
